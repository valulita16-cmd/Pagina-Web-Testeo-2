{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of EliteProteinKitchen",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the user registered"
        },
        "hasSeenOnboarding": {
          "type": "boolean",
          "description": "Whether the user has seen the onboarding"
        }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles"
    }
  }
}
